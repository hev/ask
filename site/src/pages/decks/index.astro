---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const decks = (
	await getCollection("decks", ({ data }) => !data.draft && !data.unlisted)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base
	title="decks — hev ask"
	description="Slide decks from hev ask — talks and walkthroughs, built from markdown."
	current="docs"
>
	<main>
		<header class="page-header">
			<p class="kicker">decks</p>
			<h1>Slide decks.</h1>
			<p class="lede">
				Talks and walkthroughs, rendered as full-screen decks. Built from
				markdown in the repo — easy to riff on, easy to hand off.
			</p>
		</header>

		{
			decks.length === 0 ? (
				<p class="empty">
					No decks yet. They live in <code>src/content/decks/</code>.
				</p>
			) : (
				<div class="deck-list">
					{decks.map((d) => (
						<a href={`/decks/${d.id}`} class="deck-card">
							<div class="deck-meta">
								<time datetime={d.data.pubDate.toISOString()}>
									{d.data.pubDate.toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
									})}
								</time>
								<span class="dot" aria-hidden="true">
									·
								</span>
								<span class="open">open deck →</span>
							</div>
							<h2 class="deck-title">{d.data.title}</h2>
							{d.data.description && (
								<p class="deck-summary">{d.data.description}</p>
							)}
						</a>
					))}
				</div>
			)
		}
	</main>
</Base>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 4rem 2rem 5rem;
	}

	.page-header {
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--rule);
		margin-bottom: 3rem;
	}

	.kicker {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 1rem;
	}

	.kicker::before {
		content: "// ";
		color: var(--signal);
	}

	h1 {
		font-family: "JetBrains Mono", monospace;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.035em;
		margin-bottom: 1rem;
	}

	.lede {
		font-size: 1.0625rem;
		color: var(--muted);
		max-width: 580px;
		line-height: 1.6;
	}

	.deck-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.deck-card {
		display: block;
		padding: 1.5rem 1.75rem;
		border: 1px solid var(--rule);
		text-decoration: none;
		color: inherit;
		background: var(--paper-warm);
		transition: border-color 0.15s;
	}

	.deck-card:hover {
		border-color: var(--signal);
	}

	.deck-meta {
		display: flex;
		gap: 0.75rem;
		align-items: center;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.6875rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 0.6rem;
	}

	.dot {
		color: var(--rule);
	}

	.open {
		color: var(--signal);
	}

	.deck-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--ink);
		margin-bottom: 0.5rem;
		line-height: 1.3;
	}

	.deck-card:hover .deck-title {
		color: var(--signal);
	}

	.deck-summary {
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}

	.empty {
		padding: 2rem 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	@media (max-width: 640px) {
		main {
			padding: 2.5rem 1.25rem 3rem;
		}
	}
</style>
